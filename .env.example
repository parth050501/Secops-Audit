# SecOps AI / Code Core Systems — Environment Variables
# Copy this to .env and fill in real values. NEVER commit the real .env.
#
# Generate secret values:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"   # SECOPS_ENCRYPTION_KEY
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"                                  # JWT_SECRET
#   python3 -c "import secrets; print(secrets.token_urlsafe(24))"                                  # POSTGRES_PASSWORD

# Core (REQUIRED in production)
ENVIRONMENT=development                 # development | qc | production
JWT_SECRET=change-this-to-a-long-random-string
SECOPS_ENCRYPTION_KEY=                  # REQUIRED in prod; if lost, stored credentials are unrecoverable

# Database — production uses Postgres (docker-compose.prod.yml); dev defaults to SQLite
POSTGRES_USER=secops
POSTGRES_PASSWORD=change-me
POSTGRES_DB=secops

# Optional — AI features (leave blank for demo mode)
ANTHROPIC_API_KEY=

# Optional — evidence upload storage (use a persistent volume in prod)
EVIDENCE_DIR=/app/data/evidence
